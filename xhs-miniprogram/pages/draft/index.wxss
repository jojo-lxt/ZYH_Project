.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 188rpx;
}

.header {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 12rpx 4rpx 28rpx;
}

.kicker {
  color: #0f766e;
  font-size: 24rpx;
  font-weight: 700;
}

.title {
  color: #1c1917;
  font-size: 44rpx;
  font-weight: 800;
}

.state-card,
.panel {
  border: 1rpx solid #d6d3d1;
  border-radius: 16rpx;
  background: #ffffff;
  padding: 24rpx;
}

.state-card {
  color: #57534e;
  text-align: center;
}

.state-card.error {
  color: #b42318;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.image-card {
  position: relative;
  height: 300rpx;
  overflow: hidden;
  border-radius: 14rpx;
  background: #ede9e2;
}

.image-card image {
  width: 100%;
  height: 100%;
}

.image-card text {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  min-width: 40rpx;
  border-radius: 999rpx;
  background: rgba(28, 25, 23, 0.74);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 40rpx;
  text-align: center;
}

.panel {
  margin-top: 22rpx;
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.panel-head text {
  color: #1c1917;
  font-size: 30rpx;
  font-weight: 700;
}

textarea {
  width: 100%;
  min-height: 240rpx;
  color: #292524;
  font-size: 28rpx;
  line-height: 1.7;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  min-height: 48rpx;
  border: 1rpx solid #c7d7d2;
  border-radius: 999rpx;
  background: #edf7f4;
  color: #115e59;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 48rpx;
  padding: 0 18rpx;
}

.footer {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  border-top: 1rpx solid #d6d3d1;
  background: rgba(247, 245, 241, 0.96);
  padding: 22rpx 24rpx 34rpx;
}

.primary {
  background: #0f766e;
  color: #ffffff;
}
